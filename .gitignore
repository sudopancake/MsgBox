# Local LiteDB database + sample thread (not migrations)
# This app uses LiteDB, not EF migrations. The file Data/msgbox.db is created on
# first run; DatabaseInitializer seeds John/Jane demo chats into an empty DB.
# Ignore it so local/sample data is never committed.
Data/*.db
Data/*.db-shm
Data/*.db-wal
Data/msgbox-*.db
**/msgbox.db

# Uploaded files from local dev (subfolders recreated on startup)
wwwroot/uploads/

# User secrets / local-only config
appsettings.*.local.json
secrets.json
